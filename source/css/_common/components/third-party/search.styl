mark.search-keyword {
  padding: 0;
  color: $accent-text-fill-color-primary;

  +dark() {
    color: $accent-text-fill-color-primary-dark;
  }

  +supports-light-dark() {
    color: light-dark($accent-text-fill-color-primary, $accent-text-fill-color-primary-dark);
  }
}

.search-pop-overlay {
  display: flex;
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  transition: background .167s;
  visibility: hidden;
  z-index: 4;
  background: none;

  .search-active & {
    visibility: visible;
    background: $smoke-fill-color-default;

    +dark() {
      background: $smoke-fill-color-default-dark;
    }

    +supports-light-dark() {
      background: light-dark($smoke-fill-color-default, $smoke-fill-color-default-dark);
    }
  }

  .search-popup {
    margin: auto;
    display: flex;
    flex-direction: column;
    padding: 24px;
    min-width: 320px;
    max-width: 548px;
    min-height: 184px;
    max-height: 756px;
    box-sizing: border-box;
    overflow: auto;
    color: $text-fill-color-primary;
    background: $solid-background-fill-color-base;
    border: 1px solid $surface-stroke-color-default;
    border-radius: $overlay-corner-radius;

    @media (max-width: 320px) {
      min-width: 100%;
    }

    @media (max-width: 548px) {
      max-width: 100%;
    }

    @media (max-height: 184px) {
      min-height: 100%;
    }

    @media (max-height: 756px) {
      max-height: 100%;
    }

    +dark() {
      color: $text-fill-color-primary-dark;
      background: $solid-background-fill-color-base-dark;
      border: 1px solid $surface-stroke-color-default-dark;
    }

    +supports-light-dark() {
      color: light-dark($text-fill-color-primary, $text-fill-color-primary-dark);
      background: light-dark($solid-background-fill-color-base, $solid-background-fill-color-base-dark);
      border: 1px solid light-dark($surface-stroke-color-default, $surface-stroke-color-default-dark);
    }

    .search-header {
      display: flex;
      justify-content: space-between;
      margin-bottom: 12px;

      .search-title {
        font-size: 20px;
        margin: 0;
      }

      .popup-btn-close {
        float: right;
        padding: 6px 8px;
        fill: currentColor;
        background: none;
        border: none;
        cursor: pointer;

        svg {
          margin-bottom: -3px;
        }
      }
    }

    .search-input-container {
      margin-bottom: 10px;
      position: relative;
      width: 100%;
      float: left;
      flex: 1;

      input {
        width: 100%;
        padding-right: 30px;

        &:not(:disabled):hover {
          +.search-icon {
            fill: $text-fill-color-secondary;
          }
        }

        &:not(:disabled):active {
          +.search-icon {
            fill: $text-fill-color-tertiary;
          }
        }

        &:not(:disabled):active,
        &:not(:disabled):focus-within:not(:active) {
          padding-right: 30px;
        }

        +dark() {
          &:not(:disabled):hover {
            +.search-icon {
              fill: $text-fill-color-secondary-dark;
            }
          }

          &:not(:disabled):active {
            +.search-icon {
              fill: $text-fill-color-tertiary-dark;
            }
          }
        }

        +supports-light-dark() {
          &:not(:disabled):hover {
            +.search-icon {
              fill: light-dark($text-fill-color-secondary, $text-fill-color-secondary-dark);
            }
          }

          &:not(:disabled):active {
            +.search-icon {
              fill: light-dark($text-fill-color-tertiary, $text-fill-color-tertiary-dark);
            }
          }
        }
      }

      .search-icon {
        position: absolute;
        top: 7.5px;
        right: 10px;
        fill: $text-fill-color-secondary;
        pointer-events: none;

        +dark() {
          fill: $text-fill-color-secondary-dark;
        }

        +supports-light-dark() {
          fill: light-dark($text-fill-color-secondary, $text-fill-color-secondary-dark);
        }
      }
    }

    .search-result-container {
      flex: 1;
      width: 100%;
      display: flex;
      overflow: inherit;
      flex-direction: column;

      .search-result {
        margin-top: 4px;
      }

      .search-result-list {
        overflow: inherit;
        padding: 0 0 0 18px;

        a {
          color: $text-fill-color-primary;

          &:hover {
            color: $text-fill-color-secondary;

            mark.search-keyword {
              color: $accent-text-fill-color-secondary;
            }
          }

          &:active {
            color: $text-fill-color-tertiary;

            mark.search-keyword {
              color: $accent-text-fill-color-tertiary;
            }
          }

          &:not([href]),
          &:not([href]):hover {
            color: $text-fill-color-disabled;

            mark.search-keyword {
              color: $accent-text-fill-color-disabled;
            }
          }

          +dark() {
            color: $text-fill-color-primary-dark;

            &:hover {
              color: $text-fill-color-secondary-dark;

              mark.search-keyword {
                color: $accent-text-fill-color-secondary-dark;
              }
            }

            &:active {
              color: $text-fill-color-tertiary-dark;

              mark.search-keyword {
                color: $accent-text-fill-color-tertiary-dark;
              }
            }

            &:not([href]),
            &:not([href]):hover {
              color: $text-fill-color-disabled-dark;

              mark.search-keyword {
                color: $accent-text-fill-color-disabled-dark;
              }
            }
          }

          +supports-light-dark() {
            color: light-dark($text-fill-color-primary, $text-fill-color-primary-dark);

            &:hover {
              color: light-dark($text-fill-color-secondary, $text-fill-color-secondary-dark);

              mark.search-keyword {
                color: light-dark($accent-text-fill-color-secondary, $accent-text-fill-color-secondary-dark);
              }
            }

            &:active {
              color: light-dark($text-fill-color-tertiary, $text-fill-color-tertiary-dark);

              mark.search-keyword {
                color: light-dark($accent-text-fill-color-tertiary, $accent-text-fill-color-tertiary-dark);
              }
            }

            &:not([href]),
            &:not([href]):hover {
              color: light-dark($text-fill-color-disabled, $text-fill-color-disabled-dark);

              mark.search-keyword {
                color: light-dark($accent-text-fill-color-disabled, $accent-text-fill-color-disabled-dark);
              }
            }
          }
        }
      }
    }
  }
}